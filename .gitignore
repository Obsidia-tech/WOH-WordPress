# WordPress core — track the theme/plugins you own, not core itself
wp-admin/
wp-includes/

# Uploads — never commit media
wp-content/uploads/

# Plugins — reinstallable, commercial licenses, too large for git
# Track only custom plugins you wrote from scratch (add exceptions below)
wp-content/plugins/

# Caches and generated files
wp-content/cache/
wp-content/cache-old/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# Sensitive config — NEVER commit
wp-config.php
wp-salt.php
.env

# DB export — one-time pull artifact, not tracked
*.sql

# Manuals — PDFs served via external CDN, URLs must never change
# Files live locally at ~/Sites/woh-wordpress/manuals/ for reference
# Future use: scan for maintenance actions to populate Task Templates
manuals/

# Cloudways connector file
bv_connector_*.php

# OS clutter
.DS_Store
Thumbs.db

# Logs
*.log
error_log

# Node / build artifacts
node_modules/
vendor/
